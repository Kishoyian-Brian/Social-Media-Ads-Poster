DATABASE_URL="postgresql://user:password@localhost:5432/social"
JWT_SECRET="change-me-in-production"
PORT=4000

# Use your Render HTTPS URLs in production
PUBLIC_URL="https://your-api.onrender.com"
CORS_ORIGIN="https://your-frontend.onrender.com"

# X (Twitter) OAuth 2.0
X_CLIENT_ID=""
X_CLIENT_SECRET=""
X_OAUTH_REDIRECT_URI="https://your-api.onrender.com/api/users/x/callback"
X_OAUTH_FRONTEND_REDIRECT="https://your-frontend.onrender.com/dashboard"

# TikTok OAuth 2.0 — Web Login Kit requires HTTPS redirect URIs
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""
TIKTOK_OAUTH_REDIRECT_URI="https://your-api.onrender.com/api/users/tiktok/callback"
TIKTOK_OAUTH_FRONTEND_REDIRECT="https://your-frontend.onrender.com/dashboard"
# Start with login: user.info.basic
# After Content Posting API is enabled: user.info.basic,video.publish,video.upload
# TIKTOK_OAUTH_SCOPES="user.info.basic,video.publish,video.upload"

# Local dev (TikTok Web requires HTTPS — use ngrok or deploy to test TikTok connect)
# PUBLIC_URL="http://localhost:4000"
# CORS_ORIGIN="http://localhost:5173"
# X_OAUTH_REDIRECT_URI="http://localhost:4000/api/users/x/callback"
# X_OAUTH_FRONTEND_REDIRECT="http://localhost:5173/dashboard"

# Email (OTP) — use Resend on Render FREE tier (SMTP ports 587/465 are blocked)
# https://resend.com — free tier, verify your domain or use their test sender
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM="Social Manager <onboarding@yourdomain.com>"

# Or SMTP (works locally; on Render requires PAID instance for Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-gmail-app-password-with-no-spaces
SMTP_FROM=your@gmail.com
# Or MAIL_HOST, MAIL_PORT, MAIL_USER, MAIL_PASS, MAIL_FROM

# X_API_URL="https://api.twitter.com/2/tweets"
# X_MEDIA_UPLOAD_URL="https://upload.twitter.com/1.1/media/upload.json"
# X_BEARER_TOKEN=""
